model Playbook {
  id          String      @id @default(cuid())
  gameId      String
  name        String
  version     Int
  createdAt   DateTime    @default(now())
  description String?
  template    Json
  characters  Character[]
  game        Game        @relation(fields: [gameId], references: [id])

  @@unique([gameId, name, version])
}
